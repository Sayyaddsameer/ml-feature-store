# ============================================================
# Feature Store Client — Environment Variables
# Copy this file to .env and adjust values for your setup.
# Never commit .env to version control.
# ============================================================

# ----- Kafka -----
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
RAW_EVENTS_TOPIC=raw-events
FEATURES_UPDATE_TOPIC=features-store-updates
KAFKA_CONSUMER_GROUP_ID=feature-store-consumer-group
KAFKA_CONSUMER_POLL_TIMEOUT=1.0
KAFKA_PRODUCER_DELIVERY_TIMEOUT_MS=10000

# ----- PostgreSQL -----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=feature_store
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_MIN_CONNECTIONS=1
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_CONNECT_RETRY_ATTEMPTS=5
POSTGRES_CONNECT_RETRY_BASE_DELAY=2.0

# ----- FastAPI / Uvicorn -----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
